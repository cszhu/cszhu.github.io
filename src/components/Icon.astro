---

{
	icon && (
		<svg
			viewBox={icon.viewBox}
			width="1.1em"
			height="1.1em"
			fill="currentColor"
			aria-hidden="true"
			focusable="false"
		>
			<path d={icon.path} />
		</svg>
	)
}
