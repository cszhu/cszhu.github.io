---
import HeaderLink from "./HeaderLink.astro";
import { title, subtitle } from "../settings/settings.json"
import personalData from "../data/personal.json";

const { social } = personalData;
---

<header>
	<div class="header-section">
		<div class="header-frame">
			<div class="header-text">
				<h1>{title}</h1>
				<h2>{subtitle}</h2>
			</div>
			<img src="https://avatars.githubusercontent.com/u/8116601?v=4" alt="Christina Zhu" class="avatar" />
		</div>
	</div>
</header>
<nav>
	<HeaderLink href="/">home</HeaderLink>
	<HeaderLink href="/about">about</HeaderLink>
	<HeaderLink href="/posts">blog</HeaderLink>
	{
		social
			.filter((link) => link.name !== "Email" && link.name !== "Twitter")
			.map((link) => (
				<HeaderLink href={link.url} target="_blank" rel="noopener noreferrer">
					{link.name.toLowerCase()}
				</HeaderLink>
			))
	}
</nav>
<style>
	h2 {
		margin: 0.5em 0;
	}
	.header-frame {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2rem;
		flex-wrap: wrap;
	}
	.header-text {
		flex: 1;
		min-width: 200px;
	}
	.avatar {
		width: 150px;
		height: 150px;
		border-radius: 50%;
		flex-shrink: 0;
	}
	@media (max-width: 600px) {
		.header-frame {
			flex-direction: column;
			align-items: center;
			text-align: center;
		}
		.header-text {
			width: 100%;
		}
	}
</style>
